# Copy this file to .env and fill in your own values.
# .env is git-ignored — never commit real secrets.

# Azure AI Foundry / Azure OpenAI resource endpoint, e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com

# Key from Azure AI Foundry > your project > Keys and Endpoint
AZURE_OPENAI_API_KEY=your-api-key-here

# The deployment name you created in Azure AI Foundry (not the base model name)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version, update as Azure rolls out new ones
AZURE_OPENAI_API_VERSION=2024-10-21
